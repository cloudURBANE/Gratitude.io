# Server
PORT=5000
NODE_ENV=development

# Auth
SESSION_SECRET=change-me-dev
JWT_SECRET=change-me-dev-jwt

# Database (Docker compose exposes these)
POSTGRES_USER=dev
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=appdb
DATABASE_URL=postgresql://dev:devpassword@localhost:5432/appdb

# Optional third-party keys (leave blank for local dev)
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
GOOGLE_CLOUD_PROJECT=
GCS_BUCKET=